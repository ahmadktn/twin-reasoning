# ── LLM Backend ───────────────────────────────────────────────────────────────
USE_LOCAL_LLM=false

# API provider: "openrouter" (default/free) | "anthropic" | "openai"
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-...
LLM_MODEL=mistralai/mistral-7b-instruct
# LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# ── Local model (only when USE_LOCAL_LLM=true) ────────────────────────────────
# LOCAL_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.1

# ── Data ───────────────────────────────────────────────────────────────────────
DATASET_PATH=data/All_Beauty.jsonl
DATA_DIR=data
